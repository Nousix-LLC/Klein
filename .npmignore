tsconfig.json
tsconfig.build.json
eslint.config.js
vitest.config.ts
.prettierrc.json
.prettierignore
.gitignore
.eslintcache

# Tests & coverage
tests/
coverage/
**/*.test.ts
**/*.spec.ts
*.tsbuildinfo
