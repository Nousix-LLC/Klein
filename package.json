{
  "name": "klein",
  "version": "0.1.0",
  "description": "Klein — a production-grade tree-walking interpreter for a small dynamic language.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "bin": {
    "klein": "bin/klein.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/node": "20.19.43",
    "@vitest/coverage-v8": "3.2.7",
    "eslint": "9.39.5",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "3.2.7"
  }
}
